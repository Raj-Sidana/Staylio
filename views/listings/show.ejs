<% layout("/layouts/boilerplate.ejs") %>
    <div class="row">

        <div class="col-md-8 offset-3 mt-2">

            <h3>
                <%= listing.title %>
            </h3>

        </div>

        <div class="card col-md-6 offset-3">
            <img src="<%= listing.image.url %>" class="card-img-top show_img" alt="listing_image">
            <div class="card-body">
                <p class="card-text">
                    <%= listing.description %><br>
                        <%= listing.location %><br>
                            <%= listing.country %><br>
                                <%= listing.price.toLocaleString("en-IN") %><br>
                </p>
            </div>
        </div>


    </div>

    <div class="show-btns">
        <form method="GET" class="offset-3 edit-btn" action="/listings/<%= listing._id %>/edit"> <button
                class="btn btn-primary">Edit</button> </form>

        <form method="POST" class="offset-1" action="/listings/<%= listing._id %>/?_method=DELETE"> <button
                class="btn btn-danger">Delete</button> </form>
    </div>

    <hr>

    <div class="col-md-8 offset-3 mt-2">


        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div>
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" step="1" class="form-range" id="rating" name="review[rating]">
            </div>

            <div>
                <label for="comment" class="form-label">Comment</label>
                <textarea class="form-control" name="review[comment]" id="comment" cols="30" rows="5"
                    required></textarea>
                <div class="invalid-feedback">
                    Please enter a comment.
                </div>
            </div>
            <br>
            <button class="btn btn-outline-dark">Submit</button>
        </form>
    </div>