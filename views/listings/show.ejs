<% layout("/layouts/boilerplate.ejs") %>
<div class="row">

    <div class="col-md-8 offset-3 mt-2">

        <h3> Listing Details </h3>

    </div>

    <div class="card col-md-6 offset-3">
        <img src="<%= listing.image.url %>" class="card-img-top show_img" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
        <b><%= listing.title %></b> <br>
        <%= listing.description %><br>
        <%= listing.location %><br>
        <%= listing.country %><br>
        <%= listing.price.toLocaleString("en-IN") %><br>
    </p>
    </div>
    </div>
    

</div>

 <div class="show-btns">
        <form method="GET" class="btn offset-3 edit-btn" action="/listings/<%= listing._id %>/edit"> <button>Edit</button> </form>
        
        <form method="POST" class="btn btn-dark offset-1" action="/listings/<%= listing._id %>/?_method=DELETE"> <button>Delete</button> </form>
    </div>

    