<% layout("/layouts/boilerplate.ejs") %>

    <h3 class="index-heading">All Listings</h3>
        <br><br>

        <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2">
            <% for(let listing of allListings) {%>
                <a href="/listings/<%= listing._id %>" class="listing-links">
            <div class="card col" >
             <img src=<%= listing.image.url %>" style="height: 20rem;" class="card-img-top" alt="listing image">
             <h5 class="card-title"><%= listing.title %></h5>
             <div class="card-img-overlay"></div>
             <div class="card-body">
                <p class="card-text">
                    &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                </p>
             </div>
            </div>
            </a>
            <% } %>
        </div>